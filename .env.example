# Server-only URL. Do not expose this as a NEXT_PUBLIC variable.
PINCHANA_API_URL=http://localhost:8080

# Tag assigned to images built by Docker Compose.
PINCHANA_WEB_IMAGE=pinchana-web:latest

# Public Turnstile widget site key registered for this web hostname.
# Cloudflare's documented always-pass test key can be used locally.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key

# Optional public build revision. Builds use the current Git commit when the
# repository metadata is available and fall back to this deployment value.
NEXT_PUBLIC_PINCHANA_WEB_COMMIT=your-public-git-commit

# Server-only Ed25519 public key used to verify project-issued certificates for
# custom Pinchana API origins. Preserve PEM newlines with \n in one-line env UIs.
PINCHANA_INSTANCE_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nreplace-with-project-public-key\n-----END PUBLIC KEY-----"
